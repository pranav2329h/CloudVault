PORT=5000
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_URI=mongodb://admin:password@mongodb:27017/?authSource=admin
DATABASE_NAME=cloudvault
SECRET_KEY=change-this-secret-key
JWT_SECRET_KEY=change-this-jwt-secret-key
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://cloudvault-pranav.duckdns.org
STORAGE_BACKEND=s3
AWS_REGION=eu-north-1
AWS_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
PRESIGNED_URL_EXPIRY=300
MAX_FILE_SIZE=104857600
DEFAULT_STORAGE_LIMIT_BYTES=16106127360
BACKEND_IMAGE=pranav2329h/cloudvault-backend:latest
