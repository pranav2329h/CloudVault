pipeline {
    agent any

    options {
        timestamps()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        APP_NAME = "cloudvault-backend"
        PYTHON = "python3"
    }

    stages {

        stage('Checkout Source') {
            steps {
                echo "========== CHECKOUT =========="
                checkout scm
            }
        }

        stage('Workspace Info') {
            steps {
                sh '''
                echo "Current Directory:"
                pwd

                echo ""
                echo "Workspace Files:"
                ls -la
                '''
            }
        }

        stage('Python Version') {
            steps {
                sh '''
                python3 --version
                pip3 --version
                '''
            }
        }

        stage('Create Virtual Environment') {
            steps {
                dir('backend') {
                    sh '''
                    python3 -m venv venv

                    . venv/bin/activate

                    pip install --upgrade pip
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('backend') {
                    sh '''
                    . venv/bin/activate

                    pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Verify Installation') {
            steps {
                dir('backend') {
                    sh '''
                    . venv/bin/activate

                    pip list
                    '''
                }
            }
        }

    }

    post {

        success {
            echo "Stage 1 Completed Successfully"
        }

        failure {
            echo "Pipeline Failed"
        }

        always {
            cleanWs()
        }
    }
}
