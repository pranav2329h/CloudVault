pipeline {

    agent any

    options {

        timestamps()

        ansiColor('xterm')

        buildDiscarder(logRotator(
            numToKeepStr: '10'
        ))

    }

    environment {

        IMAGE_NAME = "cloudvault-backend"

        IMAGE_TAG = "${BUILD_NUMBER}"

        DOCKERHUB = "pranav2329h"

    }

    stages {

        stage('Checkout') {

            steps {

                checkout scm

            }

        }

        stage('Python Version') {

            steps {

                sh 'python3 --version'

            }

        }

        stage('Install Dependencies') {

            steps {

                sh '''
                python3 -m venv venv

                . venv/bin/activate

                pip install --upgrade pip

                pip install -r backend/requirements.txt
                '''

            }

        }

        stage('Run Tests') {

            steps {

                sh '''
                . venv/bin/activate

                python -m unittest discover backend || true
                '''

            }

        }

        stage('Build Docker Image') {

            steps {

                script {

                    docker.build("${DOCKERHUB}/${IMAGE_NAME}:${IMAGE_TAG}", "./backend")

                }

            }

        }

    }

}