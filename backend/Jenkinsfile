pipeline {
    agent any

    options {
        timestamps()
        ansiColor('xterm')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {
        APP_NAME = "cloudvault-backend"
        DOCKER_USERNAME = "pranav2329h"
        IMAGE_NAME = "${DOCKER_USERNAME}/${APP_NAME}"
        BUILD_TAG = "${BUILD_NUMBER}"
    }

    stages {

        stage('Checkout Source') {
            steps {
                echo "========== CHECKOUT =========="
                checkout scm
            }
        }

        stage('Workspace Info') {
            steps {
                sh '''
                echo "========== WORKSPACE =========="
                pwd

                echo ""
                echo "Workspace Files:"
                ls -la
                '''
            }
        }

        stage('Python Version') {
            steps {
                sh '''
                echo "========== PYTHON VERSION =========="
                python3 --version
                pip3 --version
                '''
            }
        }

        stage('Create Virtual Environment') {
            steps {
                dir('backend') {
                    sh '''
                    echo "========== CREATE VENV =========="

                    python3 -m venv venv

                    . venv/bin/activate

                    pip install --upgrade pip
                    '''
                }
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('backend') {
                    sh '''
                    echo "========== INSTALL DEPENDENCIES =========="

                    . venv/bin/activate

                    pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Verify Installation') {
            steps {
                dir('backend') {
                    sh '''
                    echo "========== VERIFY PACKAGES =========="

                    . venv/bin/activate

                    pip list
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('backend') {
                    sh '''
                    echo "========== BUILD DOCKER IMAGE =========="

                    docker build \
                    -t ${IMAGE_NAME}:${BUILD_TAG} \
                    -t ${IMAGE_NAME}:latest \
                    .
                    '''
                }
            }
        }

        stage('Docker Login') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'dockerhub-creds',
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )
                ]) {

                    sh '''
                    echo "========== DOCKER LOGIN =========="

                    echo "$DOCKER_PASS" | docker login \
                    -u "$DOCKER_USER" \
                    --password-stdin
                    '''
                }
            }
        }

        stage('Push Docker Image') {
            steps {
                sh '''
                echo "========== PUSH IMAGE =========="

                docker push ${IMAGE_NAME}:${BUILD_TAG}

                docker push ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy to EC2') {
            steps {

                sshagent(credentials: ['ec2-ssh-key']) {

                    withCredentials([
                        string(
                            credentialsId: 'deployment-ip',
                            variable: 'DEPLOY_HOST'
                        )
                    ]) {

                        sh '''
                        echo "========== DEPLOY TO EC2 =========="

                        chmod +x /var/lib/jenkins/scripts/deploy.sh

                        /var/lib/jenkins/scripts/deploy.sh
                        '''
                    }
                }
            }
        }

        stage('Health Check') {
            steps {

                withCredentials([
                    string(
                        credentialsId: 'deployment-ip',
                        variable: 'DEPLOY_HOST'
                    )
                ]) {

                    sh '''
                    echo "========== HEALTH CHECK =========="

                    sleep 20

                    curl --fail http://$DEPLOY_HOST:5000/health
                    '''
                }
            }
        }
    }

    post {

        success {
            echo "======================================="
            echo "PIPELINE COMPLETED SUCCESSFULLY"
            echo "======================================="
        }

        failure {
            echo "======================================="
            echo "PIPELINE FAILED"
            echo "======================================="
        }

        always {

            echo "========== CLEANUP =========="

            cleanWs()

            sh '''
            docker image prune -af || true
            '''
        }
    }
}